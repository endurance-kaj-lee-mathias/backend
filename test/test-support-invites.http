### =====================================================
### Variables
### =====================================================
@baseUrl = http://localhost:8080
@keycloakUrl = http://localhost:8180
@realm = endurance
@clientId = backend
@clientSecret = Hvkh9JcoLjjNFT8FIgd3qPpJZWT3E7v9
@usernameSupport = Lee
@usernameVeteran = Mathias
@usernameVeteran2 = Noah
@usernameTherapist = Kaj
@password = password

### =====================================================
### Auth – get tokens for all three users
### =====================================================

### Get VETERAN token
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameVeteran}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("veteranToken", response.body.access_token);
%}

### =====================================================
### 1. Get access token – VETERAN2
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameVeteran2}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("veteranToken2", response.body.access_token);
%}

### Get SUPPORT token
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameSupport}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("supportToken", response.body.access_token);
%}

### Get THERAPIST token
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameTherapist}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("therapistToken", response.body.access_token);
%}

### =====================================================
### Seed – ensure all users exist in the DB
### =====================================================

### Ensure VETERAN exists – stores veteranId
GET {{baseUrl}}/users/me
Authorization: Bearer {{veteranToken}}

> {%
    client.global.set("veteranId", response.body.id);
%}

### Ensure SUPPORT exists – stores supportId
GET {{baseUrl}}/users/me
Authorization: Bearer {{supportToken}}

> {%
    client.global.set("supportId", response.body.id);
%}

### Ensure THERAPIST exists – stores therapistId
GET {{baseUrl}}/users/me
Authorization: Bearer {{therapistToken}}

> {%
    client.global.set("therapistId", response.body.id);
%}

### =====================================================
### 1. Happy path – SUPPORT sends invite to VETERAN
###    Run seed requests above first.
###    Expected: 201 Created, status = PENDING
### =====================================================
POST {{baseUrl}}/support
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "username": "{{usernameTherapist}}"
}

> {%
    client.global.set("inviteId", response.body.id);
%}

### =====================================================
### 2. VETERAN lists pending invites
###    Expected: 200 – invite appears in incoming[]
### =====================================================
GET {{baseUrl}}/support
Authorization: Bearer {{supportToken}}

### =====================================================
### 3. SUPPORT lists pending invites
###    Expected: 200 – invite appears in outgoing[]
### =====================================================
GET {{baseUrl}}/support
Authorization: Bearer {{veteranToken}}

### =====================================================
### 4. VETERAN accepts the invite
###    Expected: 200, status = ACCEPTED
### =====================================================
PATCH {{baseUrl}}/support/eb70674f-41fd-4942-b3c9-7d104256db6e/accept
Authorization: Bearer {{supportToken}}

### =====================================================
### 5. VETERAN's support list now contains SUPPORT
###    Expected: 200 – SUPPORT appears in the list
### =====================================================
GET {{baseUrl}}/users/support
Authorization: Bearer {{veteranToken}}

### =====================================================
### 6. Error – duplicate pending invite
###    THERAPIST sends a second invite to VETERAN while
###    one is already pending.
###    Expected: 409 Conflict
### (Run request 1 first and do NOT accept yet for this to apply)
### =====================================================
POST {{baseUrl}}/support
Authorization: Bearer {{supportToken}}
Content-Type: application/json

{
  "username": "{{usernameVeteran}}"
}

### =====================================================
### 7. Error – self invite
###    Expected: 400 Bad Request
### =====================================================
POST {{baseUrl}}/support
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "username": "{{usernameVeteran}}"
}

### =====================================================
### 8. Error – wrong role (VETERAN tries to invite a THERAPIST)
###    Expected: 403 Forbidden
### =====================================================
POST {{baseUrl}}/support
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "username": "{{usernameTherapist}}"
}

### =====================================================
### 9. Happy path – THERAPIST sends invite to VETERAN,
###    VETERAN declines it.
###    Run seed requests first.
###    Expected: 204 No Content
### =====================================================
POST {{baseUrl}}/support
Authorization: Bearer {{therapistToken}}
Content-Type: application/json

{
  "username": "{{usernameVeteran}}"
}

> {%
    client.global.set("therapistInviteId", response.body.id);
%}

### VETERAN declines – Expected: 204 No Content
PATCH {{baseUrl}}/support/{{therapistInviteId}}/decline
Authorization: Bearer {{veteranToken}}

### =====================================================
### 10. After decline, THERAPIST can send a new invite
###     Expected: 201 Created (row was deleted, re-invite allowed)
### =====================================================
POST {{baseUrl}}/support
Authorization: Bearer {{therapistToken}}
Content-Type: application/json

{
  "username": "{{usernameVeteran}}"
}

> {%
    client.global.set("therapistInviteId", response.body.id);
%}

### =====================================================
### 11. Error – wrong user tries to accept
###     SUPPORT tries to accept THERAPIST's invite to VETERAN.
###     Expected: 403 Forbidden
### =====================================================
PATCH {{baseUrl}}/support/{{therapistInviteId}}/accept
Authorization: Bearer {{supportToken}}

### =====================================================
### 12. Error – invite not found
###     Expected: 404 Not Found
### =====================================================
PATCH {{baseUrl}}/support/00000000-0000-0000-0000-000000000000/accept
Authorization: Bearer {{veteranToken}}

### =====================================================
### 13. Happy path – SUPPORT sends invite to VETERAN with a note
###     Demonstrates optional note feature (max 300 chars)
###     Expected: 201 Created, status = PENDING, note included in response
### =====================================================
POST {{baseUrl}}/support
Authorization: Bearer {{supportToken}}
Content-Type: application/json

{
  "username": "{{usernameVeteran}}",
  "note": "I would like to help you with your recovery journey."
}

> {%
    client.global.set("inviteWithNoteId", response.body.id);
%}

### =====================================================
### 14. Verify note is returned in invite list
###     Expected: 200 – note field is populated
### =====================================================
GET {{baseUrl}}/support
Authorization: Bearer {{supportToken}}

### =====================================================
### 15. Get VETERAN's support list to extract a supportId
###     Expected: 200 – list of supporters/friends
### =====================================================
GET {{baseUrl}}/users/support
Authorization: Bearer {{veteranToken}}

> {%
    if (response.body && response.body.length > 0) {
        client.global.set("supporterId", response.body[0].id);
    }
%}

### =====================================================
### 16. VETERAN deletes a supporter
###     Expected: 204 No Content
### =====================================================
DELETE {{baseUrl}}/users/support/{{supporterId}}
Authorization: Bearer {{veteranToken}}

### =====================================================
### 17. Verify supporter was removed
###     Expected: 200 – supporter no longer in list
### =====================================================
GET {{baseUrl}}/users/support
Authorization: Bearer {{veteranToken}}

### =====================================================
### 18. Setup for friend deletion: SUPPORT sends invite to VETERAN
###     Expected: 201 Created
### =====================================================
POST {{baseUrl}}/support
Authorization: Bearer {{supportToken}}
Content-Type: application/json

{
  "username": "{{usernameVeteran}}"
}

> {%
    client.global.set("friendInviteId", response.body.id);
%}

### =====================================================
### 19. VETERAN accepts to create friendship
###     Expected: 200
### =====================================================
PATCH {{baseUrl}}/support/{{friendInviteId}}/accept
Authorization: Bearer {{veteranToken}}

### =====================================================
### 20. Get SUPPORT's friend list to extract friendId
###     Expected: 200 – VETERAN should be in the list
### =====================================================
GET {{baseUrl}}/users/support
Authorization: Bearer {{supportToken}}

> {%
    if (response.body && response.body.length > 0) {
        const veteran = response.body.find(u => u.username === "Mathias");
        if (veteran) {
            client.global.set("friendId", veteran.id);
        }
    }
%}

### =====================================================
### 21. SUPPORT deletes a friend
###     Expected: 204 No Content
### =====================================================
DELETE {{baseUrl}}/users/support/{{friendId}}
Authorization: Bearer {{supportToken}}

### =====================================================
### 22. Verify friend was removed from SUPPORT's list
###     Expected: 200 – friend no longer in list
### =====================================================
GET {{baseUrl}}/users/support
Authorization: Bearer {{supportToken}}

### =====================================================
### 23. Verify friend was removed from VETERAN's list too
###     Expected: 200 – SUPPORT no longer in list
### =====================================================
GET {{baseUrl}}/users/support
Authorization: Bearer {{veteranToken}}

### =====================================================
### 24. Error – delete non-existent supporter
###     Expected: 404 Not Found or 204 No Content (idempotent)
### =====================================================
DELETE {{baseUrl}}/users/support/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{veteranToken}}

