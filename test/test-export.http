### =====================================================
### Variables
### =====================================================
@baseUrl = http://localhost:8080
@keycloakUrl = http://localhost:8180
@realm = endurance
@clientId = backend
@clientSecret = Hvkh9JcoLjjNFT8FIgd3qPpJZWT3E7v9
@usernameVeteran = Mathias
@usernameSupport = Lee
@usernameTherapist = Kaj
@password = password

### =====================================================
### 1. Get access token – VETERAN
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameVeteran}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("veteranToken", response.body.access_token);
%}

### =====================================================
### 2. Get access token – SUPPORT
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameSupport}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("supportToken", response.body.access_token);
%}

### =====================================================
### 3. Get access token – THERAPIST
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameTherapist}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("therapistToken", response.body.access_token);
%}

### =====================================================
### 4. Ensure users exist – store IDs
### =====================================================

### 4a. Get or create VETERAN
GET {{baseUrl}}/users/me
Authorization: Bearer {{veteranToken}}

> {%
    client.global.set("veteranId", response.body.id);
    client.global.set("veteranUsername", response.body.username);
%}

### 4b. Get or create SUPPORT
GET {{baseUrl}}/users/me
Authorization: Bearer {{supportToken}}

> {%
    client.global.set("supportId", response.body.id);
    client.global.set("supportUsername", response.body.username);
%}

### 4c. Get or create THERAPIST
GET {{baseUrl}}/users/me
Authorization: Bearer {{therapistToken}}

> {%
    client.global.set("therapistId", response.body.id);
    client.global.set("therapistUsername", response.body.username);
%}

### =====================================================
### 5. Seed profile data – update veteran profile fields
### =====================================================

### 5a. Update phone number
PATCH {{baseUrl}}/users/me/phone-number
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "phoneNumber": "+32412345678"
}

### 5b. Update about
PATCH {{baseUrl}}/users/me/about
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "about": "Veteran looking for support and community."
}

### 5c. Update introduction
PATCH {{baseUrl}}/users/me/introduction
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "introduction": "Hi, I'm Mathias! Glad to be part of Endurance."
}

### 5d. Upsert address
PUT {{baseUrl}}/users/me/address
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "street": "Groenplaats 1",
  "locality": "Antwerpen",
  "region": "Antwerpen",
  "postalCode": "2000",
  "country": "Belgium"
}

### 5e. Set privacy to public
PATCH {{baseUrl}}/users/me/privacy
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "isPrivate": false
}

### =====================================================
### 6. Seed support relationship via invite flow
### =====================================================

### 6a. SUPPORT sends invite to VETERAN
POST {{baseUrl}}/support
Authorization: Bearer {{supportToken}}
Content-Type: application/json

{
  "username": "{{usernameVeteran}}",
  "note": "Hey Mathias, I'd like to support you!"
}

> {%
    client.global.set("supportInviteId", response.body.id);
%}

### 6b. VETERAN accepts the invite
PATCH {{baseUrl}}/support/{{supportInviteId}}/accept
Authorization: Bearer {{veteranToken}}

### 6c. THERAPIST sends invite to VETERAN
POST {{baseUrl}}/support
Authorization: Bearer {{therapistToken}}
Content-Type: application/json

{
  "username": "{{usernameVeteran}}",
  "note": "I'm a therapist and would like to help."
}

> {%
    client.global.set("therapistInviteId", response.body.id);
%}

### 6d. VETERAN accepts the therapist invite
PATCH {{baseUrl}}/support/{{therapistInviteId}}/accept
Authorization: Bearer {{veteranToken}}

### =====================================================
### 7. Seed chat messages
### =====================================================

### 7a. VETERAN starts conversation with SUPPORT
POST {{baseUrl}}/chats
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "participantId": "{{supportId}}"
}

> {%
    client.global.set("conversationId", response.body.id);
%}

### 7b. VETERAN sends a message
POST {{baseUrl}}/chats/{{conversationId}}/messages
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "content": "Hey Lee, how are you?"
}

### 7c. SUPPORT replies
POST {{baseUrl}}/chats/{{conversationId}}/messages
Authorization: Bearer {{supportToken}}
Content-Type: application/json

{
  "content": "I'm great, thanks for asking Mathias!"
}

### 7d. VETERAN sends another message
POST {{baseUrl}}/chats/{{conversationId}}/messages
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "content": "Glad to hear that. Talk soon!"
}

### =====================================================
### 8. Seed mood entries
### =====================================================

### 8a. Submit mood entry for today
POST {{baseUrl}}/mood/entries
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "date": "2026-03-09",
  "moodScore": 7,
  "notes": "Feeling pretty good today, went for a walk."
}

### 8b. Submit mood entry for yesterday
POST {{baseUrl}}/mood/entries
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "date": "2026-03-08",
  "moodScore": 5,
  "notes": "A bit tired but okay overall."
}

### =====================================================
### 9. Seed stress samples
### =====================================================

### 9a. Stress sample 1
POST {{baseUrl}}/stress/samples
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "user_id": "{{veteranId}}",
  "timestamp_utc": "2026-03-09T08:00:00Z",
  "window_minutes": 5,
  "mean_hr": 72.3,
  "rmssd_ms": 42.1,
  "resting_hr": 62.0,
  "steps": 350,
  "sleep_debt_hours": 1.5
}

### 9b. Stress sample 2
POST {{baseUrl}}/stress/samples
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "user_id": "{{veteranId}}",
  "timestamp_utc": "2026-03-09T14:00:00Z",
  "window_minutes": 5,
  "mean_hr": 68.9,
  "rmssd_ms": 48.7,
  "resting_hr": 60.0,
  "steps": 1200,
  "sleep_debt_hours": 1.0
}

### =====================================================
### 10. Seed calendar – therapist creates slots, veteran books
### =====================================================

### 10a. THERAPIST creates urgent slot
POST {{baseUrl}}/calendar/slots
Authorization: Bearer {{therapistToken}}
Content-Type: application/json

{
  "startTime": "2026-03-15T09:00:00Z",
  "endTime": "2026-03-15T10:00:00Z",
  "isUrgent": true
}

> {%
    client.global.set("urgentSlotId", response.body.id);
%}

### 10b. THERAPIST creates second urgent slot to fill quota
POST {{baseUrl}}/calendar/slots
Authorization: Bearer {{therapistToken}}
Content-Type: application/json

{
  "startTime": "2026-03-15T10:00:00Z",
  "endTime": "2026-03-15T11:00:00Z",
  "isUrgent": true
}

### 10c. THERAPIST creates normal slot
POST {{baseUrl}}/calendar/slots
Authorization: Bearer {{therapistToken}}
Content-Type: application/json

{
  "startTime": "2026-03-15T14:00:00Z",
  "endTime": "2026-03-15T15:00:00Z",
  "isUrgent": false
}

> {%
    client.global.set("normalSlotId", response.body.id);
%}

### 10d. VETERAN books the normal slot
POST {{baseUrl}}/calendar/slots/{{normalSlotId}}/book
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "urgent": false
}

### =====================================================
### 11. Seed sharing rules (authorization)
### =====================================================

### 11a. VETERAN allows SUPPORT to view stress scores
POST {{baseUrl}}/sharing/rules
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "viewerId": "{{supportId}}",
  "resource": "stress_scores",
  "effect": "allow"
}

### 11b. VETERAN allows THERAPIST to view mood entries
POST {{baseUrl}}/sharing/rules
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "viewerId": "{{therapistId}}",
  "resource": "mood_entries",
  "effect": "allow"
}

### 11c. VETERAN allows THERAPIST to view calendar
POST {{baseUrl}}/sharing/rules
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "viewerId": "{{therapistId}}",
  "resource": "calendar",
  "effect": "allow"
}

### =====================================================
### 12. Register device token
### =====================================================
PUT {{baseUrl}}/users/device
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "token": "test-device-token-export-abc123",
  "platform": "android"
}

### =====================================================
### 13. EXPORT – GDPR Article 15 & 20
###     This should return all seeded data above as a
###     downloadable JSON file.
### =====================================================
GET {{baseUrl}}/users/me/export
Authorization: Bearer {{veteranToken}}


