### =====================================================
### Variables
### =====================================================
@baseUrl = http://localhost:8080
@keycloakUrl = http://localhost:8180
@realm = endurance
@clientId = backend
@clientSecret = Hvkh9JcoLjjNFT8FIgd3qPpJZWT3E7v9
@username = Mathias
@password = password

### =====================================================
### Get access token from Keycloak
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type=password&
client_id={{clientId}}&
client_secret={{clientSecret}}&
username={{username}}&
password={{password}}&
scope=openid

> {%
  client.global.set("token", response.body.access_token);
%}

### =====================================================
### Sync current user (GetOrCreate)
### (Uses data from Keycloak token)
### =====================================================
GET {{baseUrl}}/users
Authorization: Bearer {{token}}

### =====================================================
### Get user by ID
### (replace with your own UUID from Keycloak)
### =====================================================
GET {{baseUrl}}/users/2e808133-794d-4ba3-8da0-e562131692fb
Authorization: Bearer {{token}}

### =====================================================
### Add SUPPORT member to VETERAN
### (replace veteranId & supportId with actual UUIDs)
### =====================================================
POST {{baseUrl}}/users/2e808133-794d-4ba3-8da0-e562131692fb/support
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": "6e58b8a2-2e53-4bbd-b8d1-2bd13d3959b4"
}

### =====================================================
### List SUPPORT members of VETERAN
### (replace veteranId)
### =====================================================
GET {{baseUrl}}/users/d2b833b8-7d28-46ae-8f3a-919cdbda00c0/support
Authorization: Bearer {{token}}
