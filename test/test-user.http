### =====================================================
### Variables
### =====================================================
@baseUrl = http://localhost:8080
@keycloakUrl = http://localhost:8180
@realm = endurance
@clientId = backend
@clientSecret = Hvkh9JcoLjjNFT8FIgd3qPpJZWT3E7v9
@usernameSupport = Lee
@usernameVeteran = Mathias
@usernameTherapist = Kaj
@password = password

### =====================================================
### Get access token from Keycloak
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameVeteran}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("veteranToken", response.body.access_token);
%}

### =====================================================
### Get access token from Keycloak
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameSupport}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("supportToken", response.body.access_token);
%}

### =====================================================
### Get access token from Keycloak
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameTherapist}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("therapistToken", response.body.access_token);
%}

### 1. Get or create the current user (VETERAN) – stores veteranId and veteranUsername
GET {{baseUrl}}/users/me
Authorization: Bearer {{veteranToken}}

> {%
    client.global.set("veteranId", response.body.id);
    client.global.set("veteranUsername", response.body.username);
%}

### 2. Get or create the current user (THERAPIST) – stores therapistId and therapistUsername
GET {{baseUrl}}/users/me
Authorization: Bearer {{therapistToken}}

> {%
    client.global.set("therapistId", response.body.id);
    client.global.set("therapistUsername", response.body.username);
%}

### 3. Get or create the current user (SUPPORT) – stores supportId and supportUsername
GET {{baseUrl}}/users/me
Authorization: Bearer {{supportToken}}

> {%
    client.global.set("supportId", response.body.id);
    client.global.set("supportUsername", response.body.username);
%}

### 4. Get a user by id
GET {{baseUrl}}/users/{{veteranId}}
Authorization: Bearer {{veteranToken}}

### 4b. Get a user by username
GET {{baseUrl}}/users/search/{{veteranUsername}}
Authorization: Bearer {{veteranToken}}


### 5. Delete current user ("me")
DELETE {{baseUrl}}/users/me
Authorization: Bearer {{veteranToken}}


### 6. List all supporters for current VETERAN
GET {{baseUrl}}/users/support
Authorization: Bearer {{veteranToken}}


### 7. SUPPORT sends invite to VETERAN via support invite flow
POST {{baseUrl}}/support
Authorization: Bearer {{supportToken}}
Content-Type: application/json

{
  "username": "{{usernameVeteran}}"
}

> {%
    client.global.set("supportInviteId", response.body.id);
%}

### 8. VETERAN accepts the support invite
PATCH {{baseUrl}}/support/{{supportInviteId}}/accept
Authorization: Bearer {{veteranToken}}

### 9. List support invites for VETERAN
GET {{baseUrl}}/support
Authorization: Bearer {{veteranToken}}

### 10. Verify SUPPORT is now listed as a supporter for VETERAN
GET {{baseUrl}}/users/support
Authorization: Bearer {{supportToken}}


### 11. Delete a specific supporter from current VETERAN
DELETE {{baseUrl}}/users/support/{{veteranId}}
Authorization: Bearer {{supportToken}}


### =====================================================
### Phone number
### =====================================================

### 14. Set phone number for current user (VETERAN)
PATCH {{baseUrl}}/users/me/phone-number
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "phoneNumber": "+32 470 12 34 56"
}

### 15. Remove phone number for current user (VETERAN) – set to null
PATCH {{baseUrl}}/users/me/phone-number
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "phoneNumber": null
}

### 16. Verify phone number is returned in user profile
GET {{baseUrl}}/users/me
Authorization: Bearer {{veteranToken}}


### =====================================================
### Address
### =====================================================

### 17. Create or update address for current user (VETERAN)
PUT {{baseUrl}}/users/me/address
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "street": "Nationalestraat 5",
  "locality": "Antwerpen",
  "region": "Vlaanderen",
  "postalCode": "2000",
  "country": "België"
}

### 18. Update address for current user (VETERAN) – upsert changes locality
PUT {{baseUrl}}/users/me/address
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "street": "Nationalestraat 5",
  "locality": "Gent",
  "region": "Vlaanderen",
  "postalCode": "2000",
  "country": "België"
}

### 19. Get address for current user (VETERAN)
GET {{baseUrl}}/users/me/address
Authorization: Bearer {{veteranToken}}

### 20. Get address – 404 when no address set yet (SUPPORT)
GET {{baseUrl}}/users/me/address
Authorization: Bearer {{supportToken}}

### 21. Validation: missing required field – should return 422
PUT {{baseUrl}}/users/me/address
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "street": "Nationalestraat 5",
  "locality": "",
  "region": "Vlaanderen",
  "postalCode": "2000",
  "country": "België"
}

### =====================================================
### Introduction
### =====================================================

### 22. Update introduction for current user (VETERAN)
PATCH {{baseUrl}}/users/me/introduction
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "introduction": "Hey everyone! I'm Kaj, a veteran finding my way through life with the support of this amazing community."
}

### 23. Validation: introduction exceeds 500 characters – should return 400
PATCH {{baseUrl}}/users/me/introduction
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "introduction": ""
}

