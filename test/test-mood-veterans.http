### =====================================================
### Variables
### =====================================================
@baseUrl = http://localhost:8080
@keycloakUrl = http://localhost:8180
@realm = endurance
@clientId = backend
@clientSecret = Hvkh9JcoLjjNFT8FIgd3qPpJZWT3E7v9
@usernameVeteran = Mathias
@usernameSupport = Lee
@password = password

### =====================================================
### 1. Get access token – VETERAN
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameVeteran}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("veteranToken", response.body.access_token);
%}

### =====================================================
### 2. Get access token – SUPPORT
### =====================================================
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type = password &
client_id = {{clientId}} &
client_secret = {{clientSecret}} &
username = {{usernameSupport}} &
password = {{password}} &
scope = openid

> {%
    client.global.set("supportToken", response.body.access_token);
%}

### =====================================================
### 3. Ensure both users exist in DB
### =====================================================

### 3a. Get or create VETERAN
GET {{baseUrl}}/users/me
Authorization: Bearer {{veteranToken}}

### 3b. Get or create SUPPORT
GET {{baseUrl}}/users/me
Authorization: Bearer {{supportToken}}

### =====================================================
### Setup – seed mood entries for the veteran
### =====================================================

### 4. Submit mood entry 1 for veteran
POST {{baseUrl}}/mood/entries
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "date": "2026-03-10",
  "moodScore": 7,
  "notes": "Feeling pretty good today."
}

### 5. Submit mood entry 2 for veteran
POST {{baseUrl}}/mood/entries
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "date": "2026-03-11",
  "moodScore": 4,
  "notes": "A bit tired, rough night."
}

### 6. Submit mood entry 3 for veteran (no notes)
POST {{baseUrl}}/mood/entries
Authorization: Bearer {{veteranToken}}
Content-Type: application/json

{
  "date": "2026-03-12",
  "moodScore": 9
}

